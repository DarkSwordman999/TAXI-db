#!/bin/bash

# =============================================
# ЛАБОРАТОРНАЯ РАБОТА №8 - TAXI
# Скрипт для запуска отчётов на Python
# =============================================

show_help() {
    echo "============================================="
    echo "  ЛАБОРАТОРНАЯ РАБОТА №8 - TAXI"
    echo "============================================="
    echo ""
    echo "ОПИСАНИЕ КОМАНД:"
    echo "  ./PYTHON task1                                - отчёт по всем водителям и классам"
    echo "  ./PYTHON task1 [водитель]                     - отчёт по конкретному водителю"
    echo "  ./PYTHON task1 [водитель] [класс]             - отчёт по водителю и классу"
    echo "  ./PYTHON task2                                - сводная таблица (водители × классы)"
    echo "  ./PYTHON task2 [класс]                        - сводная таблица с фильтром по классу"
    echo "  ./PYTHON all                                  - выполнить все задачи"
    echo ""
    echo "ПРИМЕРЫ:"
    echo "  ./PYTHON task1"
    echo "  ./PYTHON task1 Волков"
    echo "  ./PYTHON task1 Волков бизнес"
    echo "  ./PYTHON task2"
    echo "  ./PYTHON task2 комфорт"
    echo "  ./PYTHON all"
}

case "$1" in
    task1)
        if [ -z "$2" ]; then
            echo " Выполняется отчёт по всем водителям..."
            python3 taxi_report.py task1
        elif [ -z "$3" ]; then
            echo " Выполняется отчёт по водителю: $2..."
            python3 taxi_report.py task1 "$2"
        else
            echo " Выполняется отчёт по водителю: $2, класс: $3..."
            python3 taxi_report.py task1 "$2" "$3"
        fi
        ;;
    task2)
        if [ -z "$2" ]; then
            echo " Выполняется сводная таблица по всем классам..."
            python3 taxi_report.py task2
        else
            echo " Выполняется сводная таблица по классу: $2..."
            python3 taxi_report.py task2 "$2"
        fi
        ;;
    all)
        echo "============================================="
        echo "  ВЫПОЛНЕНИЕ ВСЕХ ЗАДАЧ"
        echo "============================================="
        echo ""
        echo "--- ЗАДАЧА 1: ОТЧЁТ ПО ВСЕМ ВОДИТЕЛЯМ ---"
        python3 taxi_report.py task1
        
        echo ""
        echo "--- ЗАДАЧА 2: СВОДНАЯ ТАБЛИЦА ---"
        python3 taxi_report.py task2
        ;;
    *)
        show_help
        ;;
esac
